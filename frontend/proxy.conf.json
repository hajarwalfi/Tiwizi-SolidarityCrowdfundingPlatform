{
  "/api/": {
    "target": "http://localhost:8080",
    "secure": false,
    "changeOrigin": true
  },
  "/oauth2/authorization/": {
    "target": "http://localhost:8080",
    "secure": false,
    "changeOrigin": false,
    "headers": {
      "X-Forwarded-Host": "localhost:4200",
      "X-Forwarded-Proto": "http"
    }
  },
  "/login/oauth2/": {
    "target": "http://localhost:8080",
    "secure": false,
    "changeOrigin": false,
    "headers": {
      "X-Forwarded-Host": "localhost:4200",
      "X-Forwarded-Proto": "http"
    }
  }
}
